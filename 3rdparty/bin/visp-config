relpath=`dirname $0`
relpath=`(cd $relpath/..; pwd)`

PREFIX=$relpath

CFLAGS=" -fopenmp -std=c++17 -I$PREFIX/include -I/home/nguyen/visp-ws/visp/modules/tracker/tt_mi/include -I/home/nguyen/visp-ws/visp/modules/tracker/tt/include -I/home/nguyen/visp-ws/visp/modules/tracker/mbt/include -I/home/nguyen/visp-ws/visp/modules/detection/include -I/home/nguyen/visp-ws/visp/modules/vision/include -I/home/nguyen/visp-ws/visp/modules/vs/include -I/home/nguyen/visp-ws/visp/modules/visual_features/include -I/home/nguyen/visp-ws/visp/modules/robot/include -I/home/nguyen/visp-ws/visp/modules/tracker/blob/include -I/home/nguyen/visp-ws/visp/modules/ar/include -I/home/nguyen/visp-ws/visp/modules/sensor/include -I/home/nguyen/visp-ws/visp/modules/tracker/me/include -I/home/nguyen/visp-ws/visp/modules/tracker/klt/include -I/home/nguyen/visp-ws/visp/modules/io/include -I/home/nguyen/visp-ws/visp/modules/imgproc/include -I/home/nguyen/visp-ws/visp/modules/gui/include -I/home/nguyen/visp-ws/visp/modules/tracker/dnn/include -I/home/nguyen/visp-ws/visp/modules/core/include -I/usr/include/opencv4 -I/usr/include/eigen3 -I/usr/include/x86_64-linux-gnu -I/usr/include"

LIBS=" -L$PREFIX/lib -lvisp_detection -lvisp_imgproc -lvisp_robot -lvisp_sensor -lvisp_dnn_tracker -lvisp_mbt -lvisp_ar -lvisp_klt -lvisp_gui -lvisp_tt_mi -lvisp_tt -lvisp_vision -lvisp_vs -lvisp_visual_features -lvisp_blob -lvisp_me -lvisp_io -lvisp_core  -L/usr/lib/x86_64-linux-gnu -lopencv_core -lopencv_highgui -lopencv_features2d -llapack -lcblas -latlas -lz -L/usr/lib/gcc/x86_64-linux-gnu/11 -lgomp -lzbar -lopencv_objdetect -lopencv_dnn -lopencv_videoio -lopencv_imgcodecs -lopencv_imgproc -lv4l2 -lv4lconvert -ldc1394 -lopencv_video -lopencv_calib3d -lopencv_flann"

VERSION="3.7.1"

NO_NEWLINE_CHARACTER=""
NO_NEWLINE_OPTION="-n"

usage()
{
    cat <<EOF

ViSP $VERSION (Visual Servoing Platform)
Copyright (C) 2005 - 2023 Inria. All rights reserved.

Usage: $0 [--prefix] [--cflags] [--libs] [--version] [--dumpversion]  [--help]

  --prefix      Show ViSP installation prefix.
  --cflags      Print pre-processor and compiler flags including
                third party includes we depend on.
  --libs        Print library linking information with ViSP
                including third party libraries we depend on.
  --version     Output ViSP information.
  --dumpversion Output ViSP version information.
  --help        Display this help and exit.

EOF
    exit $1
}

if ! test "$1"; then
    usage;
    exit 0;
fi;

for arg in $@; do
    case $arg in
  --prefix) echo $NO_NEWLINE_OPTION "$PREFIX$NO_NEWLINE_CHARACTER";;
  --cflags) echo $NO_NEWLINE_OPTION "$CFLAGS$NO_NEWLINE_CHARACTER";;
  --libs) echo $NO_NEWLINE_OPTION "$LIBS$NO_NEWLINE_CHARACTER";;
  --version)
      echo "ViSP $VERSION (Visual Servoing Platform)"
      echo ""
      echo "Copyright (C) 2005 - 2023 Inria. All rights reserved.";;
  --dumpversion) echo $NO_NEWLINE_OPTION "$VERSION$NO_NEWLINE_CHARACTER";;
        *) usage; exit 0 ;;
    esac;
done;
echo ""
